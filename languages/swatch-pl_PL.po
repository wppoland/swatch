#. Plugin Name of the plugin
#: swatch.php
msgid "Swatch - Variation Swatches for WooCommerce"
msgstr "Swatch - próbniki wariantów dla WooCommerce"

#. Plugin URI of the plugin
#: swatch.php
msgid "https://plogins.com/swatch/"
msgstr "https://plogins.com/swatch/"

#. Description of the plugin
#: swatch.php
msgid "Replace variation dropdowns with accessible colour and label swatches."
msgstr "Zastąp listy rozwijane wariantów dostępnymi próbnikami kolorów i etykiet."

#. Author of the plugin
#: swatch.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: swatch.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: src/Admin/AttributeFields.php:68
#: src/Admin/AttributeFields.php:88
msgid "Swatch type"
msgstr "Typ próbnika"

#: src/Admin/AttributeFields.php:71
#: src/Admin/AttributeFields.php:92
msgid "Use plugin default"
msgstr "Użyj ustawienia domyślnego wtyczki"

#: src/Admin/AttributeFields.php:72
#: src/Admin/AttributeFields.php:93
#: src/Admin/Settings.php:103
msgid "Button / label"
msgstr "Przycisk / etykieta"

#: src/Admin/AttributeFields.php:73
#: src/Admin/AttributeFields.php:94
#: src/Admin/Settings.php:104
msgid "Colour"
msgstr "Kolor"

#: src/Admin/AttributeFields.php:75
msgid "How this attribute renders on the product page. Colour shows colour dots (set a colour on each term); Button shows the term name as a pill."
msgstr "Jak ten atrybut wyświetla się na stronie produktu. Kolor pokazuje kółka z kolorami (ustaw kolor dla każdego terminu); Przycisk pokazuje nazwę terminu w formie pigułki."

#: src/Admin/AttributeFields.php:96
msgid "How this attribute renders on the product page."
msgstr "Jak ten atrybut wyświetla się na stronie produktu."

#: src/Admin/AttributeFields.php:133
#: src/Admin/AttributeFields.php:156
msgid "Swatch colour"
msgstr "Kolor próbnika"

#: src/Admin/AttributeFields.php:136
#: src/Admin/AttributeFields.php:160
msgid "Used when this attribute is shown as colour swatches."
msgstr "Używany, gdy ten atrybut jest wyświetlany jako próbniki kolorów."

#: src/Admin/AttributeFields.php:139
#: src/Admin/AttributeFields.php:164
msgid "Swatch label"
msgstr "Etykieta próbnika"

#: src/Admin/AttributeFields.php:141
#: src/Admin/AttributeFields.php:167
msgid "Optional short label for button swatches. Defaults to the term name."
msgstr "Opcjonalna krótka etykieta dla próbników w formie przycisków. Domyślnie używana jest nazwa terminu."

#: src/Admin/Settings.php:38
msgid "Swatch Settings"
msgstr "Ustawienia Swatch"

#: src/Admin/Settings.php:39
msgid "Swatch"
msgstr "Swatch"

#: src/Admin/Settings.php:74
msgid "Swatch replaces the default WooCommerce variation selects with accessible colour or label swatches. Set a colour or label per attribute term on the global attribute screens (Products → Attributes → Configure terms), then choose the default look here."
msgstr "Swatch zastępuje domyślne listy wyboru wariantów WooCommerce dostępnymi próbnikami kolorów lub etykiet. Ustaw kolor lub etykietę dla każdego terminu atrybutu na ekranach atrybutów globalnych (Produkty → Atrybuty → Konfiguruj terminy), a następnie wybierz tutaj domyślny wygląd."

#: src/Admin/Settings.php:82
msgid "Enable swatches"
msgstr "Włącz próbniki"

#: src/Admin/Settings.php:92
msgid "Replace variation dropdowns with swatches on single product pages."
msgstr "Zastąp listy rozwijane wariantów próbnikami na stronach pojedynczego produktu."

#: src/Admin/Settings.php:98
msgid "Default swatch type"
msgstr "Domyślny typ próbnika"

#: src/Admin/Settings.php:106
msgid "Used for any attribute you have not given an explicit type. Attributes with no colours configured automatically fall back to the dropdown, so this is safe to leave on “Colour”."
msgstr "Używany dla każdego atrybutu, któremu nie nadano wprost typu. Atrybuty bez skonfigurowanych kolorów automatycznie wracają do listy rozwijanej, więc można bezpiecznie pozostawić ustawienie „Kolor”."

#: swatch.php:47
msgid "Swatch - Variation Swatches for WooCommerce requires WooCommerce to be active."
msgstr "Swatch - próbniki wariantów dla WooCommerce wymaga aktywnego WooCommerce."
